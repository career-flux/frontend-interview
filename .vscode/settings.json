{
  // Hide node_modules from search results
  "search.exclude": {
    "**/node_modules": true
  },

  // Use the project's local TypeScript version
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,

  // Use ESLint flat config (eslint.config.mjs)
  "eslint.useFlatConfig": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],

  // Auto-fix ESLint issues and format with Prettier on save
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  // Keep more terminal scrollback (useful for turbo run logs)
  "terminal.integrated.scrollback": 10000,

  // Group related files together in the Explorer
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js, ${capture}.test.ts, ${capture}.test.tsx",
    "*.tsx": "${capture}.ts, ${capture}.test.ts, ${capture}.test.tsx",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "pnpm-lock.yaml, turbo.json",
    "eslint.config.mjs": ".prettierrc.json, .prettierignore",
    "next.config.ts": ".mcp.json, next-env.d.ts"
  }
}
